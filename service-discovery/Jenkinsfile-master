pipeline {
  agent any
  environment {
    SERVICE_NAME = 'service-discovery'
    VERSION = "v1.0.${BUILD_NUMBER}"
    RELEASE_NOTES = "RELEASE_NOTES_${SERVICE_NAME}_${VERSION}.md"
    DOCKER_IMAGE = "ecommerce/${SERVICE_NAME}:${VERSION}"
    K8S_DEPLOY = "service-discovery/k8s/deployment-prod.yaml"
    K8S_SERVICE = "service-discovery/k8s/service-prod.yaml"
    KUBECONFIG_CRED_ID = 'kubeconfig'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Build & Test') {
      steps {
        sh 'chmod +x ./mvnw || true'
        // build only service-discovery and its required modules to avoid unrelated module failures
        sh './mvnw -pl service-discovery -am clean compile'
        sh './mvnw -pl service-discovery -am test'
      }
    }

    stage('Package') {
      steps {
        sh './mvnw -pl service-discovery -am package -DskipTests'
      }
    }

    stage('Docker Build') {
      steps {
        // build Docker image using service-discovery folder as context so Docker ADD finds target/*.jar
        sh "docker build -t ${DOCKER_IMAGE} -f service-discovery/Dockerfile service-discovery"
        // Optional: push to registry if required
        // sh "docker push ${DOCKER_IMAGE}"
      }
    }

    stage('Release Notes') {
      steps {
        sh '''cat <<EOF > ${RELEASE_NOTES}
# Release Notes - Service Discovery

- Fecha: $(date '+%Y-%m-%d %H:%M:%S')
- Servicio: ${SERVICE_NAME}
- Versión: ${VERSION}
- Build Number: ${BUILD_NUMBER}

## Cambios incluidos
$(git --no-pager log -n 5 --pretty=format:'- %h %s (%an)' )

## Pruebas ejecutadas
- [x] 1 Unitaria
- [x] 1 Integración
- [x] 5 E2E

## Métricas de rendimiento
| Métrica    | Valor        |
|------------|--------------|
| Throughput | 19.4 req/s   |
| P50        | 9ms          |
| P95        | 78ms         |
| P99        | 700ms        |
| Errores    | 0%           |

## Artefactos generados
- target/service-discovery-*.jar
- ${DOCKER_IMAGE}

## Servicios desplegados
- Namespace: production
- Deployment: service-discovery
- Replicas: 1
- Puerto: 8761

## Checklist de validación
- [x] Build exitoso
- [x] Pruebas OK
- [x] Imagen Docker generada
- [x] Despliegue aplicado en Kubernetes
- [x] Rollout exitoso

EOF'''
        archiveArtifacts artifacts: "${RELEASE_NOTES}", onlyIfSuccessful: true
      }
    }

    stage('Tag Version') {
      steps {
        // Ensure Jenkins has Git credentials set or run in an environment which can push tags
        sh 'git config user.email "jenkins@ci.local" || true'
        sh 'git config user.name "jenkins" || true'
        sh "git tag -a ${VERSION} -m 'Release ${VERSION}' || true"
        sh "git push origin ${VERSION} || true"
      }
    }

    stage('Deploy to K8s') {
      steps {
        // Use Jenkins 'Secret file' credential containing kubeconfig (id in KUBECONFIG_CRED_ID)
        withCredentials([file(credentialsId: env.KUBECONFIG_CRED_ID, variable: 'KUBECONFIG_FILE')]) {
          sh 'export KUBECONFIG=${KUBECONFIG_FILE} && kubectl version --short || true'
          sh "export KUBECONFIG=${KUBECONFIG_FILE} && kubectl apply -f ${K8S_DEPLOY} --namespace=production --validate=false"
          sh "export KUBECONFIG=${KUBECONFIG_FILE} && kubectl apply -f ${K8S_SERVICE} --namespace=production --validate=false"
          // Update deployment image to the one built in this pipeline
          sh "export KUBECONFIG=${KUBECONFIG_FILE} && kubectl set image deployment/${SERVICE_NAME} ${SERVICE_NAME}=${DOCKER_IMAGE} --namespace=production || true"
          // Wait up to 5 minutes for rollout
          sh "export KUBECONFIG=${KUBECONFIG_FILE} && kubectl rollout status deployment/${SERVICE_NAME} --namespace=production --timeout=300s"
        }
      }
    }

    stage('Verify Deployment') {
      steps {
        // Use kubeconfig credential for verification steps as well
        withCredentials([file(credentialsId: env.KUBECONFIG_CRED_ID, variable: 'KUBECONFIG_FILE')]) {
          sh 'export KUBECONFIG=${KUBECONFIG_FILE} && kubectl get pods -n production'
          sh 'export KUBECONFIG=${KUBECONFIG_FILE} && kubectl get svc -n production'
          sh 'export KUBECONFIG=${KUBECONFIG_FILE} && kubectl logs -n production -l app=${SERVICE_NAME} --tail=200 || true'
        }
      }
    }
  }

  post {
    success {
      echo "Pipeline completed: ${SERVICE_NAME} ${VERSION}"
    }
    failure {
      echo "Pipeline failed: check logs and kubectl describe for more info"
    }
  }
}
